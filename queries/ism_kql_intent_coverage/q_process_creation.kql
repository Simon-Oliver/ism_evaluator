union isfuzzy=true SecurityEvent, WindowsEvent
| where TimeGenerated > ago(14d)
| where EventID == 4688 or tostring(pack_all()) has_any ("cmd.exe", "powershell.exe", "pwsh.exe", "wscript.exe", "cscript.exe", "mshta.exe", "wmic.exe")
| summarize Events=count(), LastSeen=max(TimeGenerated) by Type, Computer=tostring(column_ifexists("Computer", "")), EventID
