SecurityRecommendation
| where TimeGenerated > ago(30d)
| where RecommendationDisplayName has_any ("unsupported", "end of support", "end-of-support", "obsolete", "outdated")
| summarize Findings=count(), Unhealthy=countif(RecommendationState !in~ ("Healthy", "Resolved")), LastSeen=max(TimeGenerated) by RecommendationDisplayName, RecommendationState
