union isfuzzy=true SecurityRecommendation, SecurityEvent, WindowsEvent
| where TimeGenerated > ago(30d)
| where tostring(pack_all()) has_any ("SPN", "DCSync", "delegation", "Kerberos pre-auth", "reversible encryption", "sIDHistory", "Domain Admins", "Enterprise Admins", "Entra Connect", "Group Policy Preferences")
| summarize Events=count(), LastSeen=max(TimeGenerated) by Type
