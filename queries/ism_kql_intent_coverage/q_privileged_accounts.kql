union isfuzzy=true AuditLogs, SigninLogs
| where TimeGenerated > ago(30d)
| where tostring(pack_all()) has_any ("Global Administrator", "Privileged", "Owner", "User Access Administrator", "admin")
| extend User = case(isnotempty(tostring(column_ifexists("UserPrincipalName", ""))), tostring(column_ifexists("UserPrincipalName", "")), isnotempty(tostring(column_ifexists("Identity", ""))), tostring(column_ifexists("Identity", "")), "unknown")
| summarize Events=count(), LastSeen=max(TimeGenerated) by Type, User
