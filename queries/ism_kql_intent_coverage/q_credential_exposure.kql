union isfuzzy=true SecurityAlert, AzureDiagnostics, SecurityEvent, WindowsEvent
| where TimeGenerated > ago(30d)
| where tostring(pack_all()) has_any ("credential", "password", "secret", "token", "clear text", "plaintext")
| summarize Events=count(), LastSeen=max(TimeGenerated) by Type, Alert=tostring(column_ifexists("AlertName", column_ifexists("Title", "")))
